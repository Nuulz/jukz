{
  "schemaVersion": 1,
  "id": "jukz",
  "version": "${version}",
  "name": "Joining Every Known Zone (JUKZ)",
  "description": "Per-world UUID with serverless P2P discovery: each world lives in one place at a time, with rotating host ownership.",
  "authors": ["Nobz"],
  "contact": {},
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main": [
      { "adapter": "kotlin", "value": "dev.jukz.JukzMod" }
    ],
    "client": [
      { "adapter": "kotlin", "value": "dev.jukz.JukzClient" }
    ]
  },
  "mixins": [
    "jukz.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.16.5",
    "minecraft": "~1.21.1",
    "java": ">=21",
    "fabric-api": "*",
    "fabric-language-kotlin": ">=1.12.0"
  }
}
